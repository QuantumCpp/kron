# ============================================================================
# kron — Configuración de clangd
# .clangd corregido para C++20
# ============================================================================

CompileFlags:
  # Directorio de build donde CMake genera compile_commands.json
  CompilationDatabase: build/
  
  # Flags de compilación para el análisis estático
  Add:
    - "-std=c++20"
    - "-Iinclude"
    - "-Wall"
    - "-Wextra"
    - "-Wpedantic"
    - "-Wconversion"
    - "-Wsign-conversion"
    - "-Wshadow"
    - "-Wno-unused-parameter"
    - "-Wno-unused-variable"
    - "-Wno-sign-compare"

Diagnostics:
  # Configuración de clang-tidy para análisis de performance y modernización
  ClangTidy:
    Add:
      - "modernize-*"
      - "performance-*"
      - "readability-identifier-naming"
      - "readability-braces-around-statements"
      - "bugprone-*"
    Remove:
      - "modernize-use-trailing-return-type"
      - "readability-magic-numbers"
      - "bugprone-easily-swappable-parameters"
      - "modernize-pass-by-value"

Index:
  # Indexación en segundo plano para rapidez en proyectos grandes
  Background: Build
  StandardLibrary: true

Completion:
  # Incluye símbolos de todos los archivos indexados
  AllScopes: true

Hover:
  # Muestra información extendida sobre tipos y plantillas
  ShowAKA: true

InlayHints:
  # Muestra visualmente los nombres de los parámetros en las llamadas
  ParameterNames: true
  # Muestra los tipos deducidos en 'auto'
  DeducedTypes: true
  # Muestra los tipos en Structured Bindings
  Designators: true
  # Muestra tipos de retorno implícitos
  FunctionReturnTypes: true

# ============================================================================
# NOTA PARA NEOVIM (nvim-lspconfig):
# El error 'Limit' ocurría porque no es una opción válida en el archivo .clangd.
# Debes configurar el límite de resultados en tu init.lua de la siguiente forma:
#
# require('lspconfig').clangd.setup({
#   cmd = { "clangd", "--limit-results=50", "--header-insertion=never" }
# })
# ============================================================================
